{
  "name": "frontend",
  "version": "1.0.0",
  "main": " ",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "workspaces": [
    "kesaseteli/*",
    "benefit/*",
    "shared"
  ],
  "engines": {
    "node": ">=24.17.0",
    "pnpm": "11.5.0"
  },
  "scripts": {
    "audit": "npx lerna-audit --level=high --groups=dependencies",
    "build": "pnpm exec lerna run build",
    "ks-empl:build": "cross-env pnpm exec lerna run --scope @frontend/employer --stream build",
    "ks-hdlr:build": "cross-env pnpm exec lerna run --scope @frontend/ks-handler --stream build",
    "ks-youth:build": "cross-env pnpm exec lerna run --scope @frontend/youth --stream build",
    "bf-appl:build": "cross-env pnpm exec lerna run --scope @frontend/applicant --stream build",
    "bf-hdlr:build": "cross-env pnpm exec lerna run --scope @frontend/bf-handler --stream build",
    "ks-empl:dev": "pnpm exec lerna run --scope @frontend/employer --stream dev",
    "ks-hdlr:dev": "pnpm exec lerna run --scope @frontend/ks-handler --stream dev",
    "ks-youth:dev": "pnpm exec lerna run --scope @frontend/youth --stream dev",
    "bf-appl:dev": "pnpm exec lerna run --scope @frontend/applicant --stream dev",
    "bf-hdlr:dev": "pnpm exec lerna run --scope @frontend/bf-handler --stream dev",
    "ks-empl:start": "pnpm exec lerna run --scope  @frontend/employer --stream start",
    "ks-hdlr:start": "pnpm exec lerna run --scope  @frontend/ks-handler --stream start",
    "ks-youth:start": "pnpm exec lerna run --scope  @frontend/youth --stream start",
    "bf-appl:start": "pnpm exec lerna run --scope  @frontend/applicant --stream start",
    "bf-hdlr:start": "pnpm exec lerna run --scope  @frontend/bf-handler --stream start",
    "release": "cross-env HUSKY_BYPASS=true && pnpm exec lerna publish",
    "husky:pre-commit": "pnpm exec lerna run --concurrency 1 --stream pre-commit",
    "typecheck": "pnpm exec lerna run typecheck",
    "lint": "pnpm exec lerna run lint",
    "test": "pnpm exec lerna run test --concurrency 1 --stream",
    "test:debug": "pnpm exec lerna run test:debug",
    "test:staged": "pnpm exec lerna run test:staged",
    "test:coverage": "pnpm exec lerna run test:coverage --stream --concurrency 1",
    "bf-appl:test": "pnpm --dir benefit/applicant run test",
    "bf-hdlr:test": "pnpm --dir benefit/handler run test",
    "bf-appl:browser-test": "pnpm --dir benefit/applicant run browser-test",
    "bf-appl:browser-test:ci": "pnpm --dir benefit/applicant run browser-test:ci",
    "ks-empl:test": "pnpm --dir kesaseteli/employer run test",
    "ks-empl:browser-test": "pnpm --dir kesaseteli/employer run browser-test",
    "ks-empl:browser-test:ci": "pnpm --dir kesaseteli/employer run browser-test:ci",
    "ks-youth:test": "pnpm --dir kesaseteli/youth run test",
    "ks-youth:browser-test": "pnpm --dir kesaseteli/youth run browser-test",
    "ks-youth:browser-test:ci": "pnpm --dir kesaseteli/youth run browser-test:ci",
    "shared:test": "pnpm --dir shared run test",
    "ks-shared:test": "pnpm --dir kesaseteli/shared run test",
    "fix-hds-shim": "node ./scripts/fix-hds-core-cookie-consent.js"

  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "lerna-update-wizard": "^1.1.2",
    "picocolors": "1.0.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.3.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^6.0.0-alpha.6",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@next/eslint-plugin-next": "^12.2.6",
    "@swc/core": "^1.4.6",
    "@swc/jest": "^0.2.36",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^14.3.0",
    "@testing-library/testcafe": "^4.4.1",
    "@testing-library/user-event": "^14.1.1",
    "@types/faker": "^5.5.9",
    "@types/jest": "^27.4.0",
    "@types/jest-axe": "^3.5.3",
    "@types/leaflet": "^1.7.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.2",
    "@types/pretty": "^2.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-input-mask": "2.0.5",
    "@types/react-leaflet": "^2.8.2",
    "@types/react-leaflet-markercluster": "^3.0.0",
    "@types/react-table": "^7.7.0",
    "@types/styled-components": "^5.1.24",
    "@types/uuid": "^8.3.1",
    "@typescript-eslint/eslint-plugin": "^5.28.0",
    "@typescript-eslint/parser": "^5.9.1",
    "@typescript-eslint/typescript-estree": "^5.13.0",
    "audit-ci": "^6.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.4.1",
    "eslint-config-adjunct": "4.11.1",
    "eslint-config-airbnb": "^19.0.2",
    "eslint-config-airbnb-typescript": "^16.1.0",
    "eslint-config-auto": "0.7.1",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-array-func": "^3.1.7",
    "eslint-plugin-chai-expect": "^3.0.0",
    "eslint-plugin-chai-friendly": "^0.7.2",
    "eslint-plugin-const-case": "^1.2.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-html": "^6.2.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^26.1.0",
    "eslint-plugin-jest-async": "^1.0.3",
    "eslint-plugin-jest-dom": "^4.0.1",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-lodash": "^7.3.0",
    "eslint-plugin-lodash-fp": "^2.2.0-a1",
    "eslint-plugin-markdown": "^2.2.1",
    "eslint-plugin-no-constructor-bind": "^2.0.4",
    "eslint-plugin-no-secrets": "^0.8.9",
    "eslint-plugin-no-unsanitized": "^4.0.1",
    "eslint-plugin-no-use-extend-native": "^0.5.0",
    "eslint-plugin-optimize-regex": "^1.2.1",
    "eslint-plugin-pii": "^1.0.2",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.3.0",
    "eslint-plugin-scanjs-rules": "^0.2.1",
    "eslint-plugin-security": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-sonarjs": "^0.11.0",
    "eslint-plugin-switch-case": "^1.1.2",
    "eslint-plugin-testing-library": "^5.1.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-xss": "^0.1.12",
    "eslint-plugin-you-dont-need-lodash-underscore": "^6.12.0",
    "faker": "^5.5.3",
    "husky": "^9.1.7",
    "i18next": "^25.3.2",
    "jest": "^27.4.7",
    "jest-axe": "^6.0.0",
    "lerna": "^8.0.2",
    "lerna-audit": "^1.3.3",
    "lint-staged": "^12.3.1",
    "lodash": "^4.17.21",
    "next": "15.5.19",
    "next-router-mock": "0.9.12",
    "nock": "^13.5.0",
    "prettier": "^2.5.1",
    "pretty": "^2.0.0",
    "react-i18next": "^15.6.0",
    "testcafe": "^3.6.2",
    "testcafe-reporter-html": "^1.4.6",
    "ts-jest": "^27.1.3",
    "typescript": "^5.9.3"
  }
}
